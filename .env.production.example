NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (host must be the container name)
DATABASE_URL=postgresql://alexandria:<password>@alexandria-postgres:5432/alexandria
POSTGRES_USER=alexandria
POSTGRES_PASSWORD=<password>
POSTGRES_DB=alexandria

# Auth
SECRET=<jwt-secret>

# Email (required in production/staging)
RESEND_API_KEY=re_...
SERVER_URL=https://api.tryalexandria.com

# CORS
CORS_ORIGIN=https://tryalexandria.com

# Machine translation (optional — clients fall back to MyMemory when unset)
# Free-plan keys end with ':fx'
DEEPL_API_KEY=
