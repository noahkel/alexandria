# Non-secret runtime config for the Cloud Function.
# Secrets (SECRET, DATABASE_URL, DEEPL_API_KEY) are managed with
# `firebase functions:secrets:set` and must NOT be added to this file.
SERVER_URL=https://alexandria-noahk.web.app
CORS_ORIGIN=https://alexandria-noahk.web.app
DATABASE_SSL=true
# satisfies env validation; signup verification emails silently fail, which is
# harmless (login does not require a verified address). To enable real emails,
# see "Enabling signup emails" in docs/firebase-deployment.md
RESEND_API_KEY=placeholder
