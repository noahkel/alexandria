{
  "functions": [
    {
      "source": "functions",
      "runtime": "nodejs22",
      "predeploy": ["node scripts/prepare-functions.mjs"]
    }
  ],
  "hosting": {
    "public": "frontend/dist",
    "predeploy": ["npm run build:web"],
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/verify/**",
        "function": "api"
      },
      {
        "source": "/health",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
